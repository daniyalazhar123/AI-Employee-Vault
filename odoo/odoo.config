# ============================================
# ODOO CONFIGURATION FILE
# ============================================
# Personal AI Employee Hackathon 0
# Platinum Tier - Odoo Community Edition
# ============================================

[options]
# --------------------------------------------
# Server Configuration
# --------------------------------------------
admin_passwd = admin_master_password_change_me
db_host = db
db_port = 5432
db_user = odoo
db_password = odoo_secure_password_123
db_name = odoo_production

# Server Settings
http_port = 8069
http_interface = 0.0.0.0
workers = 2
max_cron_threads = 1

# --------------------------------------------
# Security (Platinum Tier)
# --------------------------------------------
secure_proxy_headers = X-Forwarded-For, X-Forwarded-Proto, X-Forwarded-Host
proxy_mode = True

# Session Security
session_timeout = 3600
auth_signup_reset_password = True
auth_signup_template_mfa = False

# --------------------------------------------
# Logging (Gold Tier Requirement)
# --------------------------------------------
logfile = /var/log/odoo/odoo.log
log_level = info
log_handler = :INFO
log_db = False

# --------------------------------------------
# Performance
# --------------------------------------------
limit_memory_hard = 2684354560
limit_memory_soft = 2147483648
limit_request = 8192
limit_time_cpu = 60
limit_time_real = 120

# --------------------------------------------
# Database
# --------------------------------------------
db_maxconn = 64
db_template = template1

# --------------------------------------------
# Data Directory
# --------------------------------------------
data_dir = /var/lib/odoo

# --------------------------------------------
# Addons Paths
# --------------------------------------------
addons_path = /mnt/extra-addons,/usr/lib/python3/dist-packages/odoo/addons

# --------------------------------------------
# Translations
# --------------------------------------------
translate_modules = ['all']

# --------------------------------------------
# Demo Mode (Disable in Production)
# --------------------------------------------
demo = False

# --------------------------------------------
# PLATINUM TIER: Cloud Deployment Settings
# --------------------------------------------
# For cloud deployment, uncomment and configure:
# --------------------------------------------
# smtp_server = smtp.gmail.com
# smtp_port = 587
# smtp_user = your-email@gmail.com
# smtp_password = your-app-password
# email_from = noreply@your-domain.com
# --------------------------------------------

# ============================================
# HACKATHON REQUIREMENTS
# ============================================
# This configuration supports:
# - Gold Tier: Odoo MCP integration
# - Platinum Tier: Cloud deployment
#
# Modules to Install:
# 1. Invoicing (account_invoice)
# 2. CRM (crm)
# 3. Sales (sale_management)
# 4. Contacts (base)
# 5. Discuss (mail)
# ============================================
