# ============================================
# AI Employee Vault - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!
# ============================================

# --------------------------------------------
# Gmail API Configuration
# --------------------------------------------
# Get credentials from: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8080/

# --------------------------------------------
# Odoo CRM Configuration (Optional)
# --------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DATABASE=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=your_password_or_api_key_here

# --------------------------------------------
# Qwen CLI Configuration
# --------------------------------------------
# API key for Qwen (if using API instead of local)
QWEN_API_KEY=your_api_key_here

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_RETENTION_DAYS=7

# --------------------------------------------
# Watcher Configuration
# --------------------------------------------
GMAIL_CHECK_INTERVAL=120
WHATSAPP_CHECK_INTERVAL=30
OFFICE_CHECK_INTERVAL=1
SOCIAL_CHECK_INTERVAL=1

# Maximum retries for failed operations
MAX_RETRIES=3

# --------------------------------------------
# Vault Paths (Optional - defaults to script parent)
# --------------------------------------------
# VAULT_PATH=C:/Users/YourName/Documents/Obsidian Vault
