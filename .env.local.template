# ============================================
# 🏠 PLATINUM TIER - LOCAL ENVIRONMENT
# ============================================
# Copy this file to .env.local on Local machine
# NEVER commit this file to Git!
# NEVER sync to Cloud VM!

# LOCAL AGENT - FULL ACCESS CREDENTIALS
# These credentials have FINAL EXECUTE permissions
# Keep secure and private!

# --------------------------------------------
# Email (Full Access - Can Send)
# --------------------------------------------
GMAIL_CLIENT_ID=your_local_gmail_client_id
GMAIL_CLIENT_SECRET=your_local_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_local_gmail_refresh_token
GMAIL_REDIRECT_URI=http://localhost:8080

# --------------------------------------------
# WhatsApp (Local Only - Session)
# --------------------------------------------
WHATSAPP_SESSION_PATH=C:/Users/CC/Documents/Obsidian Vault/whatsapp_session
WHATSAPP_PHONE=+1234567890

# --------------------------------------------
# Banking (Local Only - Final Execute)
# --------------------------------------------
BANK_API_URL=https://your-bank-api.com
BANK_API_KEY=your_local_bank_api_key
BANK_USERNAME=your_bank_username
BANK_PASSWORD=your_bank_password
BANK_MAX_PAYMENT_AMOUNT=50000

# --------------------------------------------
# Odoo (Full Access - Can Post)
# --------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_production
ODOO_USERNAME=local_admin
ODOO_API_KEY=local_full_access_api_key
ODOO_MODE=execute

# --------------------------------------------
# Social Media (Full Access - Can Post)
# --------------------------------------------
LINKEDIN_CLIENT_ID=your_local_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_local_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=full_access_linkedin_token
LINKEDIN_ORGANIZATION_ID=your_organization_id

FACEBOOK_APP_ID=your_local_facebook_app_id
FACEBOOK_APP_SECRET=your_local_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=full_access_facebook_token
FACEBOOK_PAGE_ID=your_facebook_page_id

INSTAGRAM_ACCESS_TOKEN=full_access_instagram_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_id

TWITTER_API_KEY=your_local_twitter_api_key
TWITTER_API_SECRET=your_local_twitter_api_secret
TWITTER_BEARER_TOKEN=full_access_twitter_token
TWITTER_ACCOUNT_ID=your_twitter_account_id

# --------------------------------------------
# Local Machine Configuration
# --------------------------------------------
LOCAL_AGENT_MODE=execute
LOCAL_MACHINE_ID=local-desktop
LOCAL_TIMEZONE=Asia/Karachi

# --------------------------------------------
# Security Settings
# --------------------------------------------
ALLOW_FINAL_SEND=true
ALLOW_PAYMENT_EXECUTE=true
ALLOW_WHATSAPP_SEND=true
REQUIRE_HUMAN_APPROVAL=true
MAX_PAYMENT_AMOUNT=50000
BULK_EMAIL_LIMIT=100

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=local_agent.log
AUDIT_LOG_ENABLED=true
SECURITY_AUDIT_ENABLED=true

# --------------------------------------------
# Git Sync
# --------------------------------------------
GIT_SYNC_INTERVAL=300
GIT_REMOTE=origin
GIT_BRANCH=main
