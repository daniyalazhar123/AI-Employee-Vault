# ============================================
# ☁️ PLATINUM TIER - CLOUD ENVIRONMENT
# ============================================
# Copy this file to .env.cloud on Cloud VM
# NEVER commit this file to Git!
# NEVER sync to Local machine!

# CLOUD AGENT - DRAFT ONLY CREDENTIALS
# These credentials should have DRAFT-ONLY permissions
# No final send/execute rights

# --------------------------------------------
# Email (Read/Draft only - No Send)
# --------------------------------------------
GMAIL_CLIENT_ID=your_cloud_gmail_client_id
GMAIL_CLIENT_SECRET=your_cloud_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_cloud_gmail_refresh_token
GMAIL_REDIRECT_URI=http://localhost:8080

# --------------------------------------------
# Odoo (Draft only - No Post)
# --------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_production
ODOO_USERNAME=cloud_user
ODOO_API_KEY=cloud_draft_only_api_key
ODOO_MODE=draft_only

# --------------------------------------------
# Social Media (Draft only - No Post)
# --------------------------------------------
LINKEDIN_CLIENT_ID=your_cloud_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_cloud_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=draft_only_linkedin_token

FACEBOOK_APP_ID=your_cloud_facebook_app_id
FACEBOOK_APP_SECRET=your_cloud_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=draft_only_facebook_token

INSTAGRAM_ACCESS_TOKEN=draft_only_instagram_token

TWITTER_API_KEY=your_cloud_twitter_api_key
TWITTER_API_SECRET=your_cloud_twitter_api_secret
TWITTER_BEARER_TOKEN=draft_only_twitter_token

# --------------------------------------------
# Cloud VM Configuration
# --------------------------------------------
CLOUD_AGENT_MODE=draft_only
CLOUD_VM_ID=oracle-cloud-arm-vm
CLOUD_REGION=us-ashburn-1

# --------------------------------------------
# Security Settings
# --------------------------------------------
ALLOW_FINAL_SEND=false
ALLOW_PAYMENT_EXECUTE=false
ALLOW_WHATSAPP_SEND=false
REQUIRE_LOCAL_APPROVAL=true

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=cloud_agent.log
AUDIT_LOG_ENABLED=true
