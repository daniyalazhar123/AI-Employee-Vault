# ============================================
# AI Employee Vault - .gitignore
# ============================================

# 🔐 Sensitive Credentials & Auth
config/credentials.json
config/token.pickle
config/.env
.env
.env.local
.env.*.local

# 📁 Session Data (Browser/Auth Sessions)
sessions/
whatsapp_session/
*.session
*.pickle

# 📊 Processed Data (User-Specific)
data/processed_*.txt
data/tracker_*.txt

# 📝 Logs (Optional - Keep if you want history)
# Logs/*.log
# Logs/*.txt

# 🐍 Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 🐍 Virtual Environments
venv/
env/
ENV/
.venv

# 🧪 IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 📦 Node Modules (if using Qwen CLI)
node_modules/
package-lock.json

# 🧪 Testing
.pytest_cache/
.coverage
htmlcov/

# 📝 Temporary Files
*.tmp
*.temp
~*

# 🔒 OS Files
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride
mcp-email/token.json
mcp-email/token.pickle
whatsapp_session/
credentials.json
